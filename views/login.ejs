<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Freaky Fashion</title>
    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>

  <body class="auth-page">

    <header>
      <div class="site__header">
        <img src="/images/logo-mobile.webp" id="header__logotyp" alt="Freaky Fashion" />
      </div>
    </header>

    <main class="auth">

      <div class="auth__container">

        <h1>Welcome back</h1>
        <p class="auth__subtitle">Log in or create an account</p>

        <!-- LOGIN -->
        <form 
            class="auth__form" 
            action="/login" 
            method="POST"
        >
          <h2>Login</h2>

          <input name="email" type="email" placeholder="Email" required />
          <input name="password" type="password" placeholder="Password" required />

          <button type="submit">Login</button>
        </form>

        <!-- REGISTER -->
        <form class="auth__form" action="/register" method="POST">
          <h2>Create account</h2>

          <input name="first_name" placeholder="First name" required />
          <input name="last_name" placeholder="Last name" required />
          <input name="email" type="email" placeholder="Email" required />
          <input name="password" type="password" placeholder="Password" required />
          <input name="birthday" type="date" />

          <button type="submit">Sign up</button>
        </form>

      </div>

    </main>

  </body>
</html>