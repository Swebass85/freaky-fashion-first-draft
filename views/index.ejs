<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Freaky Fashion</title>
    <link rel="icon" href="icons/favicon-16px.png" />
    <link rel="stylesheet" href="stylesheets/style.css" />
  </head>
  <body>
    
    <header>
      
      <div class="site__header">
        <img src="/images/logo-mobile.webp" alt="Freaky Fashion Logo" id="header__logotyp" />
        
        <div class="header__top">
          
          <form class="header__search" action="/search" method="GET">
            
            <input 
              type="text" 
              placeholder="Sök produkt" 
              class="search__bar"
              name="q"
              >
          
          </form>
          
          
          
          <div class="header__icons">
            <img src="/icons/heart-fill.svg" alt="heart icon" class="nav__icons" id="heart__icon">
            <img src="/icons/shopping-basket.svg" alt="shopping cart icon" class="nav__icons" id="shopping__icon">
            <img src="/icons/log-in.svg" alt="login icon" class="nav__icons" id="login__icon">
          </div> <!-- /header__icons -->
        </div> <!-- /header__top -->
      </div> <!-- /site-header -->
        
        <nav class="header__nav">
          <ul>
            <li><a href="/Nyheter">Nyheter</a></li>
            <li><a href="/products">Kläder</a></li>
            <li><a href="/about">Accessoarer</a></li>
              <li><a href="/contact">Skor</a></li>
            </ul>
          </nav>
    </header>

    <main class="main">
      <section class="hero">
        <video class="hero__video" autoplay muted loop playsinline>
          <source src="/images/hero-video.mp4" type="video/mp4">
        </video>
        <div class="hero__info">
          <h1>Freaky Fashion</h1>
          <p>Välkommen till sommarens hetaste look!</p>
        </div>
        <div class="hero__info--1024-wrapper">
          <div class="hero__info--1024">
            <h1>Freaky Fashion</h1>
            <p>Välkommen till sommarens hetaste look!</p>
          </div>
        </div><!-- /hero__info--1024-wrapper -->
      </section>
      <section class="spots">
        <div class="spots__card">
          <img 
            src="/images/women/spots-women.webp" 
            class="spots__card--image"
            alt="Womens fashion image"
          >
          <div class="spots__card--overlay">
            <h1>Dam</h1>
          </div>
        </div>
        <div class="spots__card">
          <img 
            src="/images/Men/spots-men.webp" 
            class="spots__card--image"
            alt="Mens fashion image"
          >
          <div class="spots__card--overlay">
            <h1>Herr</h1>
          </div>
        </div>
        <div class="spots__card">
          <img 
            src="/images/kids/spots-kids.webp" 
            class="spots__card--image"
            alt="Kids fashion image"
          >
          <div class="spots__card--overlay">
            <h1>Barn</h1>
          </div>
        </div>
      </section>
      <section class="products">
        <% products.forEach(product => { %>
        <div class="product__card">
          <a href = "/products/<%= product.id %>" class = "product__link"> 
            <div class="product__card--wrapper">
              <div class="product__card--image-container">
                <img 
                  src="<%= product.picture_front %>" 
                  alt="<%= product.type %>" 
                  class="product__card--image product__card--image-front"
                >
                <img 
                  src="<%= product.picture_back %>"
                  alt="<%= product.type %>"
                  class="product__card--image product__card--image-back"
                > 
              </div> <!-- /product__card--image-container -->
              <% if (product.age_days <= 7) { %>
              <button class="product__card--icons nyheter">Nyheter</button>
              <% } %>
              <img src="/icons/heart.svg" alt="heart icon no fill" class="product__card--icons heart__icon--nofill">
              <div class="product__card--info">
                <div class="product__card--info--header">
                  <h3><%= product.type %></h3>
                  <p><%= product.price %> SEK</p>
                </div> <!-- /product__card--info--header -->
                <p><%= product.brand %></p>
              </div> <!-- /product__card--info -->
            </div> <!-- /product__card--wrapper -->
          </a> <!-- /product__link -->
        </div> <!-- /product__card -->
        <% }) %>   
      </section>
     
      <ul class="services-items">
        <li>
          <img src="/icons/globe.svg" alt="Free shipping icon" />
          Gratis frakt och returer
        </li>
        <li>
          <img src="/icons/airplane.svg" alt="Express delivery icon" />
          Expressfrakt
        </li>
        <li>
          <img src="/icons/shield.svg" alt="Safe payments icon" />
          Säkra betalningar
        </li>
        <li>
          <img src="/icons/smile-emoji.svg" alt="News every day icon" />
          Nyheter varje dag
        </li>
      </ul>
    </main> <!-- /main -->

    <footer>
      <!-- ACCORDION (shopping, my pages, customer service) -->

      <div class="accordion">
        <!-- Shopping -->
        <div class="accordion-container">
          <div class="accordion-item">
            <input type="checkbox" id="item-1" />
            <label for="item-1" class="accordion-header">Shopping</label>
            <div class="accordion-content">
              <ul>
                <li><a href="#">Vinterjackor</a></li>
                <li><a href="#">Pufferjackor</a></li>
                <li><a href="#">Kappa</a></li>
                <li><a href="#">Trenchcoats</a></li>
              </ul>
            </div>
          </div>

          <!-- Mina Sidor -->
          <div class="accordion-item">
            <input type="checkbox" id="item-2" aria-label="Visa Mina Sidor" />
            <label for="item-2" class="accordion-header">Mina Sidor</label>
            <div class="accordion-content">
              <ul>
                <li><a href="#">Orderhistorik</a></li>
                <li><a href="#">Adressbok</a></li>
                <li><a href="#">Sparade kort</a></li>
                <li><a href="#">Personuppgifter</a></li>
              </ul>
            </div>
          </div>

          <!-- Kundtjänst -->
          <div class="accordion-item">
            <input type="checkbox" id="item-3" aria-label="Visa kundtjänst" />
            <label for="item-3" class="accordion-header">Kundtjänst</label>
            <div class="accordion-content">
              <ul>
                <li><a href="#">Vanliga frågor</a></li>
                <li><a href="#">Retur & reklamation</a></li>
                <li><a href="#">Kontakta oss</a></li>
                <li><a href="#">Storleksguide</a></li>
              </ul>
            </div> <!-- /accordion-content -->
          </div> <!-- /accordion-item -->
        </div> <!-- /accordion-container -->
      </div> <!-- /accordion -->

      <div class="copyright">
        <p>&copy; 2024 Freaky Fashion. All rights reserved.</p>
      </div>
    </footer>
  </body>
</html>
